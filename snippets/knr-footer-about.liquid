{%- comment -%} Brand / certification block, shared by the footer's mobile and desktop layouts. {%- endcomment -%}
{%- if settings.about_heading != blank -%}<h4>{{ settings.about_heading }}</h4>{%- endif -%}
{%- if settings.about_text != blank -%}<p>{{ settings.about_text }}</p>{%- endif -%}
<div class="knr-foot__cosmos">
  {%- if settings.cosmos_logo != blank -%}
    {{ settings.cosmos_logo | image_url: width: 200 | image_tag: alt: 'Cosmos Organic', class: 'knr-cosmos-logo', widths: '100,200' }}
  {%- else -%}
    <img class="knr-cosmos-logo" src="{{ 'logo-footer.png' | asset_url }}" alt="Cosmos Organic — Cosmétique Bio" width="500" height="500">
  {%- endif -%}
</div>
{%- if settings.cert_text != blank -%}<div class="knr-foot__cert">{{ settings.cert_text }}</div>{%- endif -%}
{%- if settings.cert_link_label != blank -%}
  <a href="{{ settings.cert_link | default: '#' }}" class="knr-foot__certlink"><span>{{ settings.cert_link_label }}</span></a>
{%- endif -%}
