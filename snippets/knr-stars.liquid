{%- comment -%}
  Five-star rating.
  Usage: {% render 'knr-stars', rating: 4.7 %}
  `rating` — 0..5 (rounded to whole stars for the fill).
{%- endcomment -%}
{%- liquid
  assign value = rating | default: 5 | round
-%}
<span class="knr-stars" role="img" aria-label="{{ rating | default: 5 }} / 5">
  {%- for i in (1..5) -%}
    {%- if i <= value -%}
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="m12 2 2.9 6.3 6.9.7-5.1 4.6 1.4 6.8L12 17.8 5.9 20.4 7.3 13.6 2.2 9l6.9-.7Z"/></svg>
    {%- else -%}
      <svg viewBox="0 0 24 24" aria-hidden="true"><path class="knr-star-empty" d="m12 2 2.9 6.3 6.9.7-5.1 4.6 1.4 6.8L12 17.8 5.9 20.4 7.3 13.6 2.2 9l6.9-.7Z"/></svg>
    {%- endif -%}
  {%- endfor -%}
</span>
