{%- comment -%}
  Inline SVG icon.
  Usage: {% render 'knr-icon', name: 'search', class: 'my-class' %}
  Every icon inherits `currentColor` so colour is controlled from CSS.
{%- endcomment -%}
{%- liquid
  assign cls = class | default: ''
  assign box = '0 0 24 24'
-%}
{%- case name -%}
  {%- when 'chevron' -%}
    <svg class="{{ cls }}" viewBox="{{ box }}" fill="none" stroke="currentColor" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
  {%- when 'caret-left' -%}
    <svg class="{{ cls }}" viewBox="{{ box }}" fill="none" stroke="currentColor" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
  {%- when 'caret-right' -%}
    <svg class="{{ cls }}" viewBox="{{ box }}" fill="none" stroke="currentColor" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
  {%- when 'plus' -%}
    <svg class="{{ cls }}" viewBox="{{ box }}" fill="none" stroke="currentColor" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
  {%- when 'search' -%}
    <svg class="{{ cls }}" viewBox="{{ box }}" fill="none" stroke="currentColor" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
  {%- when 'bag' -%}
    <svg class="{{ cls }}" viewBox="{{ box }}" fill="none" stroke="currentColor" aria-hidden="true"><path d="M6 2 3 6.5V20a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6.5L18 2Z"/><path d="M3 6.5h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
  {%- when 'pin' -%}
    <svg class="{{ cls }}" viewBox="{{ box }}" fill="none" stroke="currentColor" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
  {%- when 'account' -%}
    <svg class="{{ cls }}" viewBox="{{ box }}" fill="none" stroke="currentColor" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 3.6-7 8-7s8 3 8 7"/></svg>
  {%- when 'menu' -%}
    <svg class="{{ cls }}" viewBox="{{ box }}" fill="none" stroke="currentColor" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
  {%- when 'filter' -%}
    <svg class="{{ cls }}" viewBox="{{ box }}" fill="none" stroke="currentColor" aria-hidden="true"><path d="M3 6h18M6 12h12M10 18h4"/></svg>
  {%- when 'facebook' -%}
    <svg class="{{ cls }}" viewBox="{{ box }}" fill="currentColor" aria-hidden="true"><path d="M14 9h3l.5-3H14V4.2c0-.8.3-1.2 1.3-1.2H17V.2C16.6.1 15.6 0 14.7 0 12.3 0 11 1.3 11 3.7V6H8.5v3H11v9h3V9Z"/></svg>
  {%- when 'instagram' -%}
    <svg class="{{ cls }}" viewBox="{{ box }}" fill="none" stroke="currentColor" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
  {%- when 'tiktok' -%}
    <svg class="{{ cls }}" viewBox="{{ box }}" fill="currentColor" aria-hidden="true"><path d="M16 3c.3 2 1.6 3.5 3.6 3.8v2.8c-1.3 0-2.6-.4-3.6-1.1v6.1A5.6 5.6 0 1 1 10 9v2.9a2.7 2.7 0 1 0 1.9 2.6V3H16Z"/></svg>
  {%- when 'linkedin' -%}
    <svg class="{{ cls }}" viewBox="{{ box }}" fill="currentColor" aria-hidden="true"><path d="M4.5 3.5A2 2 0 1 1 2.5 5.5 2 2 0 0 1 4.5 3.5ZM3 8h3v13H3V8Zm6 0h2.9v1.8h.05C12.4 8.7 13.7 8 15.4 8 19 8 19.7 10.3 19.7 13.4V21h-3v-6.7c0-1.6 0-3.6-2.2-3.6s-2.5 1.7-2.5 3.5V21H9V8Z"/></svg>
{%- endcase -%}
