<div class="knr-root">
  <div class="knr-announce">
    <span>{{ section.settings.text }}</span>
    {%- if section.settings.link_label != blank -%}
      <a href="{{ section.settings.link | default: '#' }}">{{ section.settings.link_label }}</a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "KNR Barre d'annonce",
  "settings": [
    { "type": "text", "id": "text", "label": "Texte", "default": "Livraison estimée sous 48h" },
    { "type": "text", "id": "link_label", "label": "Libellé du lien", "default": "consectetur." },
    { "type": "url", "id": "link", "label": "Lien" }
  ],
  "presets": [{ "name": "KNR Barre d'annonce" }]
}
{% endschema %}

{% stylesheet %}
.knr-announce { background: #000; display: flex; align-items: center; justify-content: center; gap: 3px; height: 32px; font-size: 12px; line-height: 12px; color: #fff; padding: 0 24px; }
.knr-announce a { color: #fff; text-decoration: underline; text-underline-offset: 3px; }
{% endstylesheet %}
