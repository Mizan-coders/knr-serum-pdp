{%- liquid
  assign c5 = section.settings.count_5
  assign c4 = section.settings.count_4
  assign c3 = section.settings.count_3
  assign c2 = section.settings.count_2
  assign c1 = section.settings.count_1
  assign max_count = c5
  if c4 > max_count
    assign max_count = c4
  endif
  if c3 > max_count
    assign max_count = c3
  endif
  if c2 > max_count
    assign max_count = c2
  endif
  if c1 > max_count
    assign max_count = c1
  endif
  if max_count == 0
    assign max_count = 1
  endif
-%}

<div class="knr-root">
  <section class="knr-rev" style="background-color: {{ section.settings.background }};">
    <div class="knr-wrap">
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}

      <div class="knr-rev__summary">
        <div class="knr-rev__scorecol">
          <div class="knr-rev__score">{% render 'knr-stars', rating: section.settings.rating %} &nbsp; {{ section.settings.rating }} sur 5</div>
          <div class="knr-rev__score">Basé sur {{ section.settings.total }} avis</div>
        </div>

        <div class="knr-rev__bars">
          {%- for level in (1..5) reversed -%}
            {%- liquid
              case level
                when 5
                  assign count = c5
                when 4
                  assign count = c4
                when 3
                  assign count = c3
                when 2
                  assign count = c2
                else
                  assign count = c1
              endcase
              assign width = count | times: 100 | divided_by: max_count
            -%}
            <div class="knr-rev__bar">
              {% render 'knr-stars', rating: level %}
              <div class="knr-rev__track"><div class="knr-rev__fill" style="width: {{ width }}%"></div></div>
              <span>{{ count }}</span>
            </div>
          {%- endfor -%}
        </div>

        <div class="knr-rev__cta">
          <button type="button" class="knr-btn knr-btn--dark">{{ section.settings.cta_primary }}</button>
          <button type="button" class="knr-btn knr-btn--out">{{ section.settings.cta_secondary }}</button>
        </div>
      </div>

      <div class="knr-rev__items">
        <div class="knr-rev__filter">{% render 'knr-icon', name: 'filter' %} {{ section.settings.filter_label }}</div>
        {%- for block in section.blocks -%}
          <div class="knr-rev__item" {{ block.shopify_attributes }}>
            <div class="knr-rev__row">
              {% render 'knr-stars', rating: block.settings.rating %}
              <span class="knr-rev__date">{{ block.settings.date }}</span>
            </div>
            <div class="knr-rev__who">
              {{ block.settings.name }}
              {%- if block.settings.verified -%}<span class="knr-verif">VÉRIFIÉ</span>{%- endif -%}
            </div>
            {%- if block.settings.usage != blank -%}<div class="knr-rev__use">{{ block.settings.usage }}</div>{%- endif -%}
            <p class="knr-rev__body">{{ block.settings.body }}</p>
          </div>
        {%- endfor -%}
      </div>

      {%- if section.settings.more_label != blank -%}
        <div class="knr-rev__more"><button type="button" class="knr-btn knr-btn--out">{{ section.settings.more_label }}</button></div>
      {%- endif -%}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "KNR Avis",
  "tag": "section",
  "settings": [
    { "type": "color", "id": "background", "label": "Couleur de fond", "default": "#ffffff" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "Avis clients" },
    { "type": "range", "id": "rating", "label": "Note moyenne", "min": 0, "max": 5, "step": 0.1, "default": 4.7 },
    { "type": "text", "id": "total", "label": "Total d'avis", "default": "200" },
    { "type": "header", "content": "Répartition des notes" },
    { "type": "number", "id": "count_5", "label": "5 étoiles", "default": 32 },
    { "type": "number", "id": "count_4", "label": "4 étoiles", "default": 10 },
    { "type": "number", "id": "count_3", "label": "3 étoiles", "default": 5 },
    { "type": "number", "id": "count_2", "label": "2 étoiles", "default": 6 },
    { "type": "number", "id": "count_1", "label": "1 étoile", "default": 1 },
    { "type": "header", "content": "Actions" },
    { "type": "text", "id": "cta_primary", "label": "Bouton principal", "default": "Écrire un avis" },
    { "type": "text", "id": "cta_secondary", "label": "Bouton secondaire", "default": "Poser une question" },
    { "type": "text", "id": "filter_label", "label": "Filtre", "default": "Filtrer" },
    { "type": "text", "id": "more_label", "label": "Charger plus", "default": "Charger plus" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Avis",
      "settings": [
        { "type": "text", "id": "name", "label": "Nom", "default": "Mathilde S" },
        { "type": "text", "id": "date", "label": "Date", "default": "09/02/26" },
        { "type": "range", "id": "rating", "label": "Note", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "usage", "label": "Durée d'usage", "default": "Après usage d'1 mois" },
        { "type": "checkbox", "id": "verified", "label": "Achat vérifié", "default": true },
        { "type": "richtext", "id": "body", "label": "Avis", "default": "<p>Maison Célestine est une marque de soins anti-âge haut de gamme formulés à partir d'ingrédients d'origine naturelle soigneusement sélectionnés.</p>" }
      ]
    }
  ],
  "presets": [{ "name": "KNR Avis" }]
}
{% endschema %}

{% stylesheet %}
.knr-rev { padding: 54px 0 60px; text-align: center; background: #fff; }
.knr-rev h2 { font-size: 30px; font-weight: 500; margin-bottom: 40px; }
.knr-rev__score { font-size: 13px; color: var(--knr-muted); margin-bottom: 8px; display: flex; align-items: center; justify-content: center; }
.knr-rev__scorecol { margin-bottom: 24px; }
.knr-rev__bars { max-width: 380px; margin: 0 auto 30px; }
.knr-rev__bar { display: flex; align-items: center; gap: 12px; margin: 8px 0; }
.knr-rev__bar .knr-stars svg { width: 13px; height: 13px; }
.knr-rev__track { flex: 1; height: 11px; background: #ede8dd; position: relative; border-radius: 1px; }
.knr-rev__fill { position: absolute; left: 0; top: 0; bottom: 0; background: var(--knr-tan); }
.knr-rev__bar span { width: 18px; text-align: right; font-size: 13px; color: var(--knr-muted); }
.knr-rev__cta { max-width: 560px; margin: 0 auto; }
.knr-rev__cta .knr-btn--dark { margin-bottom: 12px; }
.knr-rev__filter { display: flex; align-items: center; gap: 10px; font-size: 15px; margin: 34px 0 8px; border-bottom: 1px solid var(--knr-line); padding-bottom: 18px; }
.knr-rev__filter svg { width: 18px; height: 18px; }
.knr-rev__item { text-align: left; border-bottom: 1px solid var(--knr-line); padding: 24px 0; }
.knr-rev__row { display: flex; justify-content: space-between; align-items: center; }
.knr-rev__row .knr-stars svg { width: 14px; height: 14px; }
.knr-rev__date { font-size: 13px; color: var(--knr-muted); }
.knr-rev__who { display: flex; align-items: center; gap: 10px; margin-top: 16px; font-size: 15px; }
.knr-verif { font-size: 9px; letter-spacing: 0.1em; border: 1px solid var(--knr-line-2); padding: 3px 6px; color: var(--knr-muted); }
.knr-rev__use { font-size: 14px; margin-top: 10px; }
.knr-rev__body { font-size: 12px; line-height: 20px; letter-spacing: -0.02em; color: #4a463d; margin-top: 10px; }
.knr-rev__body p { margin: 0; }
.knr-rev__more { max-width: 560px; margin: 34px auto 0; }

@media (min-width: 900px) {
  .knr-rev .knr-wrap { max-width: 800px; }
  .knr-rev__summary { display: grid; grid-template-columns: auto 1fr 250px; gap: 40px; align-items: center; text-align: left; margin: 0 0 10px; }
  .knr-rev__scorecol { margin-bottom: 0; }
  .knr-rev__score { justify-content: flex-start; }
  .knr-rev__bars { max-width: none; margin: 0; }
  .knr-rev__cta { max-width: none; margin: 0; }
  .knr-rev__items { max-width: 720px; margin: 0 auto; }
  .knr-rev__more { max-width: 620px; }
}
{% endstylesheet %}
