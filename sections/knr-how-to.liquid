<div class="knr-root">
  <section class="knr-howto">
    <div class="knr-wrap">
      {%- if section.settings.heading != blank -%}<h2 class="knr-howto__title">{{ section.settings.heading }}</h2>{%- endif -%}
      <div class="knr-howto__track" data-knr-rail="howto" data-knr-drag>
        {%- for block in section.blocks -%}
          {%- liquid
            case forloop.index
              when 1
                assign step_asset = 'knr-gallery-hand.png'
              when 2
                assign step_asset = 'knr-editorial-face.png'
              else
                assign step_asset = 'knr-gallery-table.png'
            endcase
          -%}
          <div class="knr-step" {{ block.shopify_attributes }}>
            <div class="knr-step__img">
              {% render 'knr-image', image: block.settings.image, asset: step_asset, alt: block.settings.title, width: 760, widths: '380,600,760' %}
            </div>
            <div class="knr-step__body">
              {%- if block.settings.number != blank -%}<div class="knr-step__n">{{ block.settings.number }}</div>{%- endif -%}
              {%- if block.settings.title != blank -%}<div class="knr-step__t">{{ block.settings.title }}</div>{%- endif -%}
              {%- if block.settings.text != blank -%}<p class="knr-step__d">{{ block.settings.text }}</p>{%- endif -%}
              {%- if block.settings.link_label != blank -%}<a href="{{ block.settings.link | default: '#' }}">{{ block.settings.link_label }}</a>{%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
      {%- if section.blocks.size > 1 -%}
        <div class="knr-raildots" data-knr-dots="howto">
          {%- for block in section.blocks -%}<i {% if forloop.first %}class="on"{% endif %}></i>{%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "KNR Mode d'emploi",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titre", "default": "How to use" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Étape",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "number", "label": "Numéro", "default": "01" },
        { "type": "text", "id": "title", "label": "Titre", "default": "Découvrir" },
        { "type": "textarea", "id": "text", "label": "Texte", "default": "Concentré de pureté active. Huile végétale aux propriétés anti-oxydantes puissantes pour un éclat retrouvé." },
        { "type": "text", "id": "link_label", "label": "Libellé du lien" },
        { "type": "url", "id": "link", "label": "Lien" }
      ]
    }
  ],
  "presets": [{ "name": "KNR Mode d'emploi" }]
}
{% endschema %}

{% stylesheet %}
.knr-howto { padding: 40px 0 120px; background: #fff; }
.knr-howto__title { font-size: 32px; font-weight: 400; line-height: 40px; letter-spacing: -0.04em; color: #000; margin: 0 0 40px; }
.knr-howto__track { display: flex; gap: 8px; overflow-x: auto; scroll-snap-type: x mandatory; scrollbar-width: none; }
.knr-howto__track::-webkit-scrollbar { display: none; }
.knr-step { flex: 0 0 78%; max-width: 380px; scroll-snap-align: start; display: flex; flex-direction: column; gap: 24px; }
.knr-step__img { aspect-ratio: 1 / 1; overflow: hidden; background: var(--knr-cream); }
.knr-step__img img { width: 100%; height: 100%; object-fit: cover; }
.knr-step__body { display: flex; flex-direction: column; gap: 16px; padding: 0 24px; width: 100%; }
.knr-step__n { font-size: 14px; line-height: 14px; letter-spacing: -0.04em; text-transform: uppercase; color: var(--knr-muted); }
.knr-step__t { font-size: 24px; line-height: 32px; letter-spacing: -0.02em; font-weight: 400; }
.knr-step__d { font-size: 14px; line-height: 22px; letter-spacing: -0.02em; color: #4a463d; margin: 0; max-width: 400px; }
.knr-step a { font-size: 14px; border-bottom: 1px solid var(--knr-ink); padding-bottom: 2px; align-self: flex-start; }
.knr-raildots { display: flex; gap: 7px; justify-content: center; margin-top: 26px; }
.knr-raildots i { width: 30px; height: 2px; background: var(--knr-line-2); }
.knr-raildots i.on { background: var(--knr-ink); }

@media (min-width: 900px) {
  .knr-howto .knr-wrap { max-width: none; }
  .knr-howto__title { font-size: 32px; }
  .knr-step { flex: 0 0 calc((100% - 16px) / 3); max-width: none; }
  .knr-raildots { display: none; }
}
{% endstylesheet %}
