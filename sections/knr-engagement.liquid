{%- liquid
  assign card_product = section.settings.product
  assign card_variant = card_product.selected_or_first_available_variant
-%}

<div class="knr-root">
  <section class="knr-engage" style="background-color: {{ section.settings.background }};">
    <div class="knr-engage__bg">
      {% render 'knr-image', image: section.settings.image, asset: 'knr-dropper-oil.png', alt: section.settings.eyebrow, width: 2200, widths: '900,1400,1800,2200' %}
    </div>

    <div class="knr-wrap knr-engage__in">
      {%- if section.settings.eyebrow != blank -%}
        <span class="knr-engage__eye">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <div class="knr-engage__col">
        {%- if section.settings.quote != blank -%}<p class="knr-engage__q">{{ section.settings.quote }}</p>{%- endif -%}
        {%- if section.settings.author != blank -%}<div class="knr-engage__by">{{ section.settings.author }}</div>{%- endif -%}
      </div>
    </div>

    {%- if card_product != blank -%}
      <div class="knr-engage__card">
        <div class="knr-engage__cardleft">
          <a href="{{ card_product.url }}" class="knr-engage__cardimg">
            {{ card_product.featured_image | image_url: width: 220 | image_tag: alt: card_product.title, widths: '110,220', loading: 'lazy' }}
          </a>
          <div class="knr-engage__cardinfo">
            <h3 class="knr-engage__cardtitle">{{ card_product.title }}</h3>
            <div class="knr-engage__cardsizes">
              {%- for variant in card_product.variants limit: 2 -%}
                <span{% if forloop.first %} class="on"{% endif %}>{{ variant.title }}</span>
              {%- endfor -%}
            </div>
            <div class="knr-engage__cardprice">{{ card_variant.price | money }}</div>
          </div>
        </div>
        {%- form 'product', card_product, class: 'knr-cart-form knr-engage__cardform' -%}
          <input type="hidden" name="id" value="{{ card_variant.id }}">
          <button type="submit" class="knr-btn knr-btn--dark knr-engage__cardbtn" data-knr-add>{{ section.settings.button_label }}</button>
        {%- endform -%}
      </div>
    {%- endif -%}
  </section>
</div>

{% schema %}
{
  "name": "KNR Engagement",
  "tag": "section",
  "settings": [
    { "type": "color", "id": "background", "label": "Couleur de fond", "default": "#a39d8f" },
    { "type": "image_picker", "id": "image", "label": "Image de fond" },
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "Notre engagement pour une beauté régénérée" },
    { "type": "textarea", "id": "quote", "label": "Citation", "default": "Fusionnant l'huile de rosier muscat, le rétinol végétal et l'extrait de cactus, notre sérum pénètre en profondeur pour stimuler le renouvellement cellulaire, atténuer les rides et redonner à la peau son éclat et sa fermeté naturels." },
    { "type": "text", "id": "author", "label": "Auteur", "default": "Dr. Sophie M. · Directrice scientifique" },
    { "type": "header", "content": "Carte produit flottante" },
    { "type": "product", "id": "product", "label": "Produit" },
    { "type": "text", "id": "button_label", "label": "Bouton", "default": "Ajouter au panier" }
  ],
  "presets": [{ "name": "KNR Engagement" }]
}
{% endschema %}

{% stylesheet %}
.knr-engage { position: relative; background: var(--knr-greige); color: #fff; }
.knr-engage__bg { position: absolute; inset: 0; z-index: 0; overflow: hidden; }
.knr-engage__bg img { width: 100%; height: 100%; object-fit: cover; object-position: 50% 32%; }
.knr-engage__bg::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(120, 114, 102, 0.15) 0%, rgba(138, 132, 120, 0.5) 42%, rgba(120, 115, 104, 0.92) 100%); }
.knr-engage__in { position: relative; z-index: 1; padding-top: 240px; padding-bottom: 54px; }
.knr-engage__eye { font-size: 12px; line-height: 20px; letter-spacing: -0.02em; border-bottom: 1px solid rgba(255, 255, 255, 0.6); padding-bottom: 12px; display: inline-block; margin-bottom: 20px; color: #fff; }
.knr-engage__q { font-size: 25px; line-height: 1.34; font-weight: 400; color: #fff; margin: 0; }
.knr-engage__by { font-size: 13px; color: rgba(255, 255, 255, 0.75); margin-top: 22px; }
.knr-engage__card { display: none; }

@media (min-width: 900px) {
  .knr-engage { min-height: 720px; display: flex; align-items: center; }
  .knr-engage__bg img { object-position: 38% 40%; }
  .knr-engage__bg::after { background: linear-gradient(90deg, rgba(120, 114, 102, 0.08) 0%, rgba(132, 126, 114, 0.32) 40%, rgba(150, 144, 132, 0.7) 60%, var(--knr-greige) 86%); }
  .knr-engage__in { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; align-items: center; width: 100%; max-width: none; padding: 40px; }
  .knr-engage__col { grid-column: 2; }
  .knr-engage__eye { position: absolute; left: 40px; top: 50%; transform: translateY(-50%); margin: 0; }
  .knr-engage__q { font-size: 32px; line-height: 40px; letter-spacing: -0.04em; max-width: 510px; }
  .knr-engage__card { display: flex; position: absolute; right: 40px; bottom: -60px; z-index: 3; width: 561px; height: 120px; align-items: center; justify-content: space-between; gap: 16px; background: #fff; border: 1px solid var(--knr-soft); padding: 8px 24px 8px 8px; box-shadow: 0 14px 34px rgba(0, 0, 0, 0.1); }
  .knr-engage__cardleft { display: flex; align-items: center; gap: 16px; width: 332px; height: 104px; }
  .knr-engage__cardimg { width: 104px; height: 104px; flex: none; background: var(--knr-cream); overflow: hidden; border-radius: 2px; }
  .knr-engage__cardimg img { width: 100%; height: 100%; object-fit: cover; }
  .knr-engage__cardinfo { display: flex; flex-direction: column; gap: 6px; flex: 1; color: #000; }
  .knr-engage__cardtitle { font-size: 13px; font-weight: 400; letter-spacing: -0.02em; text-transform: uppercase; color: #000; line-height: 1.2; margin: 0; }
  .knr-engage__cardsizes { display: flex; gap: 14px; font-size: 12px; letter-spacing: -0.02em; color: #86827a; }
  .knr-engage__cardsizes .on { color: #000; border-bottom: 1.5px solid #000; padding-bottom: 2px; }
  .knr-engage__cardprice { font-size: 14px; letter-spacing: -0.02em; color: #000; }
  .knr-engage__cardform { width: 200px; flex: none; }
  .knr-root .knr-engage__cardbtn { width: 200px; height: 56px; padding: 0 24px; font-size: 13px; letter-spacing: -0.02em; white-space: nowrap; }
}
{% endstylesheet %}
